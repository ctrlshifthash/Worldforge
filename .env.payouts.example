# ── Play-to-earn env (copy the ones you need into .env) ──

# Master switch. Leave false for stub mode (no real SOL moves, fully testable).
PAYOUTS_ENABLED=false

# Solana RPC for token-balance reads + sending payouts (you'll provide the Helius URL)
HELIUS_RPC_URL=

# The gating token players must hold to earn SOL (the Solscan mint) + its total supply
PAYOUT_TOKEN_MINT=
PAYOUT_TOKEN_SUPPLY=1000000000

# Treasury wallet that pays out — base58 secret key. KEEP SECRET. Fund it with SOL.
TREASURY_SECRET_KEY=

# Global daily payout ceiling across ALL users (SOL)
PAYOUT_DAILY_CAP_SOL=5

# Stub-mode only: pretend the connected wallet holds this many tokens (test tiers locally)
STUB_TOKEN_BALANCE=0

# Privy auth (replaces email/password) — you'll provide these from the Privy dashboard
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=
