{
  "name": "worldforge",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "sh start.sh",
    "start:local": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:reset": "prisma db push --force-reset && prisma db seed",
    "setup": "npm install && prisma generate && npm run db:push && npm run db:seed"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@prisma/client": "^6.16.2",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "d3-force": "^3.0.0",
    "framer-motion": "^11.15.0",
    "jose": "^5.9.0",
    "lucide-react": "^0.460.0",
    "next": "^16.1.6",
    "prisma": "^6.16.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "simplex-noise": "^4.0.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/d3": "^7.4.3",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
