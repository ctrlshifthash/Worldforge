# ── Worldforge environment template ──
# Copy to .env (local) or set these in Railway's Variables tab. Never commit real values.

# Database — PostgreSQL connection string (Prisma Postgres / Neon / Vercel Postgres)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# JWT secret — use a strong random string in production
JWT_SECRET="change-me-to-a-random-secret"

# OpenRouter API key for AI world generation
OPENROUTER_API_KEY="sk-or-v1-your-key-here"

# ── Play-to-earn / Privy / Solana (mainnet) ──

# Master switch for real payouts. false = stub mode (no SOL moves).
PAYOUTS_ENABLED=false

# Solana RPC (Helius mainnet URL) used for token-balance reads + sending payouts
HELIUS_RPC_URL=""
SOLANA_CLUSTER="mainnet-beta"

# Privy auth (https://dashboard.privy.io)
NEXT_PUBLIC_PRIVY_APP_ID=""
PRIVY_APP_SECRET=""

# Gating token (the SPL mint players must hold to earn SOL) + total supply
PAYOUT_TOKEN_MINT=""
PAYOUT_TOKEN_SUPPLY=1000000000

# Treasury that funds payouts — set ONE:
TREASURY_SECRET_KEY=""        # base58 secret key of a funded SOL wallet
PRIVY_TREASURY_WALLET_ID=""   # or a funded Privy server wallet id

# Global daily payout ceiling across ALL users (SOL)
PAYOUT_DAILY_CAP_SOL=5

# Stub-mode only (ignored when reading real chain): simulate a holder's balance
STUB_TOKEN_BALANCE=0
